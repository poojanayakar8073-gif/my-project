# PRINT SOLUTION PATH
# ----------------------------
def print_solution(node):
    path = []
    moves = []

    while node:
        path.append(node)
        moves.append(node.move)
        node = node.parent

    path.reverse()
    moves.reverse()

    print("\n⭐ SOLUTION STEPS ⭐\n")

    for i in range(len(path)):
        print(f"Step {i}: {moves[i]}")
        path[i].display()


