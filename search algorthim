initial_state = [
    [1, 2, 3],
    [4, 0, 6],
    [7, 5, 8]
]

goal_state = [
    [1, 2, 3],
    [4, 5, 6],
    [7, 8, 0]
]

result = a_star(initial_state, goal_state)

if result:
    print_solution(result)
else:
    print("No solution found")
